## 🔧 常见任务

### 添加新的 IPC 通道

```typescript
// 1. 在主进程注册处理器
// src/main/main.ts
ipcMain.handle('feature:action', async (event, param: ParamType) => {
  try {
    const result = await performAction(param);
    return { success: true, data: result };
  } catch (error) {
    return { success: false, error: error.message };
  }
});

// 2. 在 preload 暴露 API
// src/preload/index.ts
contextBridge.exposeInMainWorld('electronAPI', {
  feature: {
    action: (param: ParamType) => ipcRenderer.invoke('feature:action', param)
  }
});

// 3. 在渲染进程使用
// src/renderer/components/Feature.tsx
const result = await window.electronAPI.feature.action(param);
```

### 添加新的 React 组件

```typescript
// 1. 创建组件文件
// src/renderer/components/MyComponent/MyComponent.tsx
import { useState } from 'react';

interface MyComponentProps {
  title: string;
  onAction: () => void;
}

export function MyComponent({ title, onAction }: MyComponentProps) {
  const [state, setState] = useState<string>('');

  return (
    <div className="my-component">
      <h2>{title}</h2>
      <button onClick={onAction}>Action</button>
    </div>
  );
}

// 2. 导出组件
// src/renderer/components/MyComponent/index.ts
export { MyComponent } from './MyComponent';

// 3. 使用组件
import { MyComponent } from '@/components/MyComponent';

<MyComponent title="Hello" onAction={handleAction} />
```

